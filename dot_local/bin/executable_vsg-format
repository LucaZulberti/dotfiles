#!/usr/bin/env bash
set -euo pipefail

orig="${1:-}"
suffix=".vhd"

tmpdir="$(mktemp -d)"
tmp="$tmpdir/input$suffix"

cleanup() {
  rm -rf "$tmpdir"
}
trap cleanup EXIT

cat > "$tmp"

config_names=(
  vsg_config.yaml vsg_config.yml vsg_config.json
  vsg.yaml vsg.yml vsg.json
  .vsg_config.yaml .vsg_config.yml .vsg_config.json
  .vsg.yaml .vsg.yml .vsg.json
)

find_config() {
  local start="$1"
  local dir="$start"

  while [ -n "$dir" ] && [ "$dir" != "/" ]; do
    for name in "${config_names[@]}"; do
      if [ -f "$dir/$name" ]; then
        printf '%s\n' "$dir/$name"
        return 0
      fi
    done
    dir="$(dirname "$dir")"
  done

  local config_home="${XDG_CONFIG_HOME:-$HOME/.config}"
  for name in "${config_names[@]}"; do
    if [ -f "$config_home/vsg/$name" ]; then
      printf '%s\n' "$config_home/vsg/$name"
      return 0
    fi
  done

  return 1
}

start_dir="$(pwd -P)"

# Helix runs the formatter from the buffer's directory.
# If orig is relative, it may be invalid from here, for example:
#   PWD=src/rtl/axi4/db
#   orig=src/rtl/axi4/db/file.vhd
# So only trust orig if it is absolute.
case "$orig" in
  /*)
    start_dir="$(dirname "$orig")"
    ;;
esac

config="$(find_config "$start_dir" || true)"

args=(-of syntastic --fix -f "$tmp")
if [ -n "$config" ]; then
  args=(-c "$config" "${args[@]}")
fi

set +e
vsg "${args[@]}" >"$tmpdir/vsg.log" 2>&1
status=$?
set -e

# VSG exit code 1 means violations were detected. That can still leave
# a usable fixed file, so do not fail Helix for 0 or 1.
if [ "$status" -gt 1 ]; then
  cat "$tmpdir/vsg.log" >&2
  exit "$status"
fi

cat "$tmp"
