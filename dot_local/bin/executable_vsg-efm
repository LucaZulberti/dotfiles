#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -lt 2 ]; then
  printf 'usage: vsg-efm MODE FILE\n' >&2
  printf 'MODE must be lint or format\n' >&2
  exit 2
fi

mode="$1"
orig="$2"

# Create temporary directory for log and format operations
tmpdir="$(mktemp -d)"

cleanup() {
  rm -rf "$tmpdir"
}
trap cleanup EXIT

config_names=(
  vsg_config.yaml vsg_config.yml vsg_config.json
  vsg.yaml vsg.yml vsg.json
  .vsg_config.yaml .vsg_config.yml .vsg_config.json
  .vsg.yaml .vsg.yml .vsg.json
)

find_config() {
  local start="$1"
  local dir="$start"

  while [ -n "$dir" ] && [ "$dir" != "/" ]; do
    for name in "${config_names[@]}"; do
      if [ -f "$dir/$name" ]; then
        printf '%s\n' "$dir/$name"
        return 0
      fi
    done
    dir="$(dirname "$dir")"
  done

  local config_home="${XDG_CONFIG_HOME:-$HOME/.config}"
  for name in "${config_names[@]}"; do
    if [ -f "$config_home/vsg/$name" ]; then
      printf '%s\n' "$config_home/vsg/$name"
      return 0
    fi
  done

  return 1
}

start_dir="$(pwd -P)"

case "$orig" in
  /*)
    start_dir="$(dirname "$orig")"
    ;;
  *)
    if [ -n "$orig" ] && [ -e "$orig" ]; then
      start_dir="$(cd "$(dirname "$orig")" && pwd -P)"
    fi
    ;;
esac

config="$(find_config "$start_dir" || true)"

vsg_args=()
if [ -n "$config" ]; then
  vsg_args=(-c "$config")
fi

# Calculate relative path of orig file with respect to config file
config_dir="$(dirname "$config")"
orig_rel="${orig#"$config_dir"/}"

case "$mode" in
  format)
    # Path to write inside the work tmpdir. When a config was found, preserve
    # the file's path relative to it (some VSG rules are path-scoped). With no
    # config -- or a file outside the config tree, where the strip above leaves
    # orig_rel absolute -- fall back to the basename so we always write inside
    # the tmpdir and never clobber the real file.
    rel="$orig_rel"
    case "$rel" in
      ""|/*) rel="$(basename "$orig")" ;;
    esac

    cd "$tmpdir"
    mkdir -p "$(dirname "$rel")"
    cat > "$rel"

    set +e
    vsg "${vsg_args[@]}" -of syntastic --fix -f "$rel" >"$tmpdir/vsg.log" 2>&1
    status=$?
    set -e

    # VSG exit code 1 means style violations were detected. With --fix,
    # this can still produce a valid formatted file.
    if [ "$status" -gt 1 ]; then
      cat "$tmpdir/vsg.log" >&2
      exit "$status"
    fi

    # Emit the fixed file so Helix/efm can replace the buffer with it.
    cat "$rel"
    ;;

  lint)
    set +e
    echo vsg "${vsg_args[@]}" -of syntastic -f "$orig_rel" >"$tmpdir/vsg.echo" 2>&1
    vsg "${vsg_args[@]}" -of syntastic -f "$orig_rel" >"$tmpdir/vsg.out" 2>"$tmpdir/vsg.err"
    status=$?
    set -e

    if [ "$status" -gt 1 ]; then
      cat "$tmpdir/vsg.out" >&2
      cat "$tmpdir/vsg.err" >&2
      exit "$status"
    fi


    cat "$tmpdir/vsg.out" "$tmpdir/vsg.err" |
      gawk -v file="$orig" '
        match($0, /^(ERROR|WARNING): [^()]+[(]([0-9]+)[)]([^[:space:]]+) -- (.*)$/, m) {
          sev = (m[1] == "ERROR") ? "E" : "W"
          printf "%s:%s:1: %s: %s -- %s\n", file, m[2], sev, m[3], m[4]
        }
      '
    ;;

  *)
    printf 'unknown mode: %s\n' "$mode" >&2
    exit 2
    ;;
esac
