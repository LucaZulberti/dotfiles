#!/usr/bin/env bash
set -euo pipefail

OUTDIR="heic"
QUALITY=82

# Portable parallel-job count: nproc (GNU/Linux) is not present on stock macOS,
# so fall back to sysctl/getconf there.
if command -v nproc >/dev/null 2>&1; then
    JOBS="$(nproc)"
else
    JOBS="$(sysctl -n hw.ncpu 2>/dev/null || getconf _NPROCESSORS_ONLN 2>/dev/null || echo 4)"
fi

# Parse arguments: --force re-converts files whose .heic already exists; any
# other argument is treated as a file extension to look for.
FORCE=0
EXTS=()
for arg in "$@"; do
    case "$arg" in
        --force | -f) FORCE=1 ;;
        *) EXTS+=("$arg") ;;
    esac
done

# Default to common image formats when no extensions were given
if [[ ${#EXTS[@]} -eq 0 ]]; then
    EXTS=(jpg jpeg png hif tiff tif webp)
fi

mkdir -p "$OUTDIR"

# Build the -iname predicates: \( -iname "*.jpg" -o -iname "*.png" -o ... \)
name_predicates=()
for ext in "${EXTS[@]}"; do
    name_predicates+=(-iname "*.${ext}" -o)
done
# Remove the trailing -o
unset 'name_predicates[-1]'

convert_file() {
    local file="$1" outdir="$2" quality="$3" force="$4"
    local base="${file##*/}"
    local stem="${base%.*}"
    local out="${outdir}/${stem}.heic"

    if [[ "$force" -eq 0 && -e "$out" ]]; then
        echo "⊘  skipped $file (already converted; use --force to redo)" >&2
        return 0
    fi

    vips heifsave "$file" "$out" --Q="$quality" \
        && echo "✓  $file -> ${stem}.heic" \
        || echo "✗  $file" >&2
}
export -f convert_file

echo Starting conversion...

find . -maxdepth 1 -type f \( "${name_predicates[@]}" \) \
| parallel -j "$JOBS" convert_file {} "$OUTDIR" "$QUALITY" "$FORCE"

echo Done.
